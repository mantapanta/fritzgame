# --- Gemini Vision (Pflicht für die automatische Erkennung) ---
# Key aus Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: Vision-Modell überschreiben (Default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Speicher (Upstash Redis) ---
# Ohne diese Variablen nutzt die App einen In-Memory-Store (nur für lokale Entwicklung,
# Daten gehen bei Neustart verloren). Auf Vercel einen Upstash-Redis-Store aus dem
# Marketplace verbinden -> die Werte werden dann automatisch gesetzt.
# Akzeptiert werden beide Namensvarianten (KV_* aus der Vercel-Integration ODER UPSTASH_*):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: Basis-URL für erzeugte Share-Links (Default: aus Request abgeleitet)
# NEXT_PUBLIC_BASE_URL=

# --- Login (Code-basiert) ---
# Zufälliges Secret für die Session/Token-Signatur. Erzeugen z.B. mit:
#   openssl rand -base64 32
AUTH_SECRET=

# Admin-Passwort für /admin (dort werden Personen angelegt und 6-stellige
# Login-Codes vergeben). Frei wählbar, geheim halten.
ADMIN_SECRET=

# Auf Vercel nicht nötig (trustHost). Lokal optional: AUTH_URL=http://localhost:3000
